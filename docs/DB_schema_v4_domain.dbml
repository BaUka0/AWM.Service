Project ETMS_v4_Domain_Sync {
  database_type: 'SQL Server'
  Note: 'Enterprise Thesis Management System v4.0 - Domain Layer Sync (Audit & Soft Delete enabled)'
}

// =============================================
// [Org] ОРГАНИЗАЦИОННАЯ СТРУКТУРА
// =============================================

Table Org.Universities {
  Id int [pk, increment]
  Name nvarchar(255) [not null]
  Code nvarchar(50) [not null, unique]
  
  // Audit
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  // Soft Delete
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

Table Org.Institutes {
  Id int [pk, increment]
  UniversityId int [not null, ref: > Org.Universities.Id]
  Name nvarchar(255) [not null]
  
  // Audit & Soft Delete
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

Table Org.Departments {
  Id int [pk, increment]
  InstituteId int [not null, ref: > Org.Institutes.Id]
  Name nvarchar(255) [not null]
  Code nvarchar(50)
  
  // Audit & Soft Delete
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

// =============================================
// [Common] ОБЩИЕ СПРАВОЧНИКИ
// =============================================

Table Common.AcademicYears {
  Id int [pk, increment]
  UniversityId int [not null, ref: > Org.Universities.Id]
  Name nvarchar(50) [not null]
  StartDate date [not null]
  EndDate date [not null]
  IsCurrent bit [default: 0]
  IsArchived bit [default: 0]
  
  // Audit & Soft Delete
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

Table Common.Periods {
  Id int [pk, increment]
  DepartmentId int [not null, ref: > Org.Departments.Id]
  AcademicYearId int [not null, ref: > Common.AcademicYears.Id]
  WorkflowStage nvarchar(100) [not null] // Enum in code
  StartDate datetime2 [not null]
  EndDate datetime2 [not null]
  IsActive bit [default: 1]
  
  // Audit & Soft Delete
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

Table Common.NotificationTemplates {
  Id int [pk, increment]
  EventType nvarchar(100) [not null, unique]
  TitleRu nvarchar(255)
  TitleKz nvarchar(255)
  TitleEn nvarchar(255)
  BodyTemplateRu nvarchar(max)
  BodyTemplateKz nvarchar(max)
  BodyTemplateEn nvarchar(max)
  
  // Audit & Soft Delete
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

Table Common.Notifications {
  Id bigint [pk, increment]
  UserId int [not null, ref: > Auth.Users.Id]
  TemplateId int [ref: > Common.NotificationTemplates.Id]
  Title nvarchar(255) [not null]
  Body nvarchar(max)
  RelatedEntityType nvarchar(50)
  RelatedEntityId bigint
  IsRead bit [default: 0]
  
  // Audit
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
}

// =============================================
// [Auth] БЕЗОПАСНОСТЬ (RBAC)
// =============================================

Table Auth.Users {
  Id int [pk, increment]
  UniversityId int [not null, ref: > Org.Universities.Id]
  Login nvarchar(100) [not null]
  Email nvarchar(255) [not null]
  PasswordHash nvarchar(max)
  ExternalId nvarchar(255)
  IsActive bit [default: 1]
  
  // Audit & Soft Delete
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

Table Auth.Roles {
  Id int [pk, increment]
  SystemName nvarchar(50) [not null, unique]
  DisplayName nvarchar(100)
  ScopeLevel nvarchar(20) [not null] // Enum in code
  
  // Audit
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
}

Table Auth.UserRoleAssignments {
  Id bigint [pk, increment]
  UserId int [not null, ref: > Auth.Users.Id]
  RoleId int [not null, ref: > Auth.Roles.Id]
  DepartmentId int [ref: > Org.Departments.Id]
  InstituteId int [ref: > Org.Institutes.Id]
  AcademicYearId int [ref: > Common.AcademicYears.Id]
  ValidFrom datetime2 [not null]
  ValidTo datetime2
  
  // Audit
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
}

