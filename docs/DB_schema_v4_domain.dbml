  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

Table Wf.States {
  Id int [pk, increment]
