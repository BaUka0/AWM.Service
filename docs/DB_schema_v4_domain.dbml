// =============================================
// [Thesis] РАБОТЫ
// =============================================

Table Thesis.Directions {
  Id bigint [pk, increment]
  DepartmentId int [not null, ref: > Org.Departments.Id]
  SupervisorId int [not null, ref: > Edu.Staff.Id]
  AcademicYearId int [not null, ref: > Common.AcademicYears.Id]
  WorkTypeId int [not null, ref: > Wf.WorkTypes.Id]
  TitleRu nvarchar(500) [not null]
  TitleEn nvarchar(500)
  TitleKz nvarchar(500)
  Description nvarchar(max)
  CurrentStateId int [not null, ref: > Wf.States.Id]
  SubmittedAt datetime2
  ReviewedAt datetime2
  ReviewedBy int
  ReviewComment nvarchar(max)
  
  // Audit & Soft Delete
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

Table Thesis.Topics {
  Id bigint [pk, increment]
  DirectionId bigint [ref: > Thesis.Directions.Id]
  AcademicYearId int [not null, ref: > Common.AcademicYears.Id]
  DepartmentId int [not null, ref: > Org.Departments.Id]
  SupervisorId int [not null, ref: > Edu.Staff.Id]
  WorkTypeId int [not null, ref: > Wf.WorkTypes.Id]
  TitleRu nvarchar(500) [not null]
  TitleEn nvarchar(500)
  TitleKz nvarchar(500)
  Description nvarchar(max)
  MaxParticipants int [default: 1]
  IsApproved bit [default: 0]
  IsClosed bit [default: 0]
  
  // Audit & Soft Delete
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

Table Thesis.TopicApplications {
  Id bigint [pk, increment]
  TopicId bigint [not null, ref: > Thesis.Topics.Id]
  StudentId int [not null, ref: > Edu.Students.Id]
  MotivationLetter nvarchar(max)
  AppliedAt datetime2
  Status nvarchar(50) [not null] // Enum in code
  ReviewedAt datetime2
  ReviewedBy int
  ReviewComment nvarchar(max)
  
  // Audit & Soft Delete
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

Table Thesis.StudentWorks {
  Id bigint [pk, increment]
  TopicId bigint [ref: > Thesis.Topics.Id]
  AcademicYearId int [not null, ref: > Common.AcademicYears.Id]
  DepartmentId int [not null, ref: > Org.Departments.Id]
  CurrentStateId int [not null, ref: > Wf.States.Id]
  FinalGrade nvarchar(10)
  IsDefended bit [default: 0]
  
  // Audit & Soft Delete
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

Table Thesis.WorkParticipants {
  Id bigint [pk, increment]
  WorkId bigint [not null, ref: > Thesis.StudentWorks.Id]
  StudentId int [not null, ref: > Edu.Students.Id]
  Role nvarchar(50) [default: 'Member'] // Enum in code
  
  // Audit (JoinedAt = CreatedAt)
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
}

Table Thesis.WorkflowHistory {
  Id bigint [pk, increment]
  WorkId bigint [not null, ref: > Thesis.StudentWorks.Id]
  FromStateId int [ref: > Wf.States.Id]
  ToStateId int [not null, ref: > Wf.States.Id]
  UserId int [not null]
  Comment nvarchar(max)
  
  // Audit (TransitionDate = CreatedAt)
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
}

Table Thesis.Attachments {
  Id bigint [pk, increment]
  WorkId bigint [not null, ref: > Thesis.StudentWorks.Id]
  StateId int [ref: > Wf.States.Id]
  AttachmentType nvarchar(50) [not null] // Enum in code
  FileName nvarchar(255) [not null]
  FileStoragePath nvarchar(1000) [not null]
  FileHash char(64) [not null]
  
  // Audit (UploadedAt/By = CreatedAt/By)
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
}

Table Thesis.Experts {
  Id int [pk, increment]
  UserId int [not null, ref: > Auth.Users.Id]
  DepartmentId int [not null, ref: > Org.Departments.Id]
  ExpertiseType nvarchar(50) [not null] // Enum in code
  IsActive bit [default: 1]
  
  // Audit & Soft Delete
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

Table Thesis.QualityChecks {
  Id bigint [pk, increment]
  WorkId bigint [not null, ref: > Thesis.StudentWorks.Id]
  CheckType nvarchar(50) [not null] // Enum in code
  AssignedExpertId int [ref: > Thesis.Experts.Id]
  AttemptNumber int [default: 1]
  IsPassed bit [not null]
  ResultValue decimal(5,2)
  Comment nvarchar(max)
  DocumentPath nvarchar(1000)
  
  // Audit (CheckedAt = CreatedAt)
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
}

Table Thesis.Reviewers {
  Id int [pk, increment]
  FullName nvarchar(255) [not null]
  Position nvarchar(255)
  AcademicDegree nvarchar(100)
  Organization nvarchar(255)
  Email nvarchar(255)
  Phone nvarchar(50)
  IsActive bit [default: 1]
  
  // Audit & Soft Delete
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

Table Thesis.Reviews {
  Id bigint [pk, increment]
  WorkId bigint [not null, ref: > Thesis.StudentWorks.Id]
  ReviewerId int [not null, ref: > Thesis.Reviewers.Id]
  ReviewText nvarchar(max)
  FileStoragePath nvarchar(1000)
  
  // Audit (UploadedAt/By = LastModifiedAt / CreatedBy)
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

Table Thesis.SupervisorReviews {
  Id bigint [pk, increment]
  WorkId bigint [not null, ref: > Thesis.StudentWorks.Id]
  SupervisorId int [not null, ref: > Edu.Staff.Id]
  ReviewText nvarchar(max) [not null]
  FileStoragePath nvarchar(1000)
  
  // Audit & Soft Delete
  CreatedAt datetime2 [not null]
  CreatedBy int [not null]
  LastModifiedAt datetime2
  LastModifiedBy int
  IsDeleted bit [not null, default: 0]
  DeletedAt datetime2
  DeletedBy int
}

